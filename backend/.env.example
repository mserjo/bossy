# backend/.env.example
# # Цей файл є прикладом конфігураційних змінних середовища.
# # Скопіюйте цей файл у .env та заповніть необхідними значеннями.
# # Не додавайте файл .env до системи контролю версій.

# --- Налаштування бази даних ---
# URL для підключення до бази даних PostgreSQL
# Приклад: POSTGRES_SERVER=db.example.com
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_app_db

# --- Налаштування SQLAlchemy ---
# Драйвер бази даних (наприклад, postgresql+asyncpg)
DB_DRIVER=postgresql+asyncpg
# Показувати SQL запити в логах (True/False)
ECHO_SQL=False

# --- Налаштування FastAPI ---
# Режим налагодження (True/False)
DEBUG=True
# Секретний ключ для JWT токенів та інших криптографічних потреб
# Згенеруйте надійний ключ, наприклад, за допомогою: openssl rand -hex 32
SECRET_KEY=your_secret_key_here
# Дозволені хости (через кому, наприклад, localhost,*.example.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Налаштування CORS ---
# Дозволені джерела для CORS (через кому)
# Приклад: http://localhost:3000,https://yourdomain.com
BACKEND_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Налаштування Redis (якщо використовується) ---
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# --- Налаштування Celery (якщо використовується) ---
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Налаштування електронної пошти (SMTP) ---
# SMTP_TLS=True
# SMTP_PORT=587
# SMTP_HOST=smtp.example.com
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_email_password
# EMAILS_FROM_EMAIL=noreply@example.com # Email відправника за замовчуванням

# --- Інші налаштування ---
# API префікс
API_V1_STR=/api/v1
# Шлях для завантажених файлів (якщо використовується)
# UPLOAD_DIR=/app/uploads

# Логування
# Рівень логування (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
# Формат логування (TEXT, JSON)
LOG_FORMAT=TEXT

# Ліміти запитів (Rate Limiting)
# REQUESTS_PER_MINUTE=100

# Налаштування для першого користувача (суперюзера)
# FIRST_SUPERUSER_EMAIL=admin@example.com
# FIRST_SUPERUSER_PASSWORD=your_strong_password
# FIRST_SUPERUSER_USERNAME=admin
