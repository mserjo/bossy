# backend/.env.example
# # Цей файл є шаблоном для конфігураційних змінних середовища.
# # Він демонструє, які змінні потрібні для запуску та роботи додатку.
# #
# # Щоб налаштувати ваше локальне середовище:
# # 1. Скопіюйте цей файл та назвіть копію `.env`.
# # 2. Відредагуйте `.env`, вказавши актуальні значення для ваших налаштувань.
# # 3. Файл `.env` не повинен додаватися до системи контролю версій (він вже є у `.gitignore`).
# #
# # УВАГА: Ніколи не зберігайте реальні секрети або паролі в цьому файлі (`.env.example`).
# # Цей файл призначений лише для прикладу структури та переліку змінних.

# --- Налаштування бази даних ---
POSTGRES_SERVER=localhost # Адреса сервера бази даних PostgreSQL
POSTGRES_PORT=5432 # Порт сервера бази даних PostgreSQL
POSTGRES_USER=your_db_user # Ім'я користувача для підключення до бази даних
POSTGRES_PASSWORD=your_db_password # Пароль для підключення до бази даних
POSTGRES_DB=your_app_db # Назва бази даних

# --- Налаштування SQLAlchemy ---
# Драйвер бази даних (наприклад, postgresql+asyncpg)
DB_DRIVER=postgresql+asyncpg
# Показувати SQL запити в логах (True/False)
ECHO_SQL=False

# --- Налаштування FastAPI ---
# Режим налагодження (True/False)
DEBUG=True
# Секретний ключ для JWT токенів та інших криптографічних потреб
# Згенеруйте надійний ключ, наприклад, за допомогою: openssl rand -hex 32
SECRET_KEY=your_secret_key_here
# Дозволені хости (через кому, наприклад, localhost,*.example.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Налаштування CORS ---
# Дозволені джерела для CORS (через кому)
# Приклад: http://localhost:3000,https://yourdomain.com
BACKEND_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Налаштування Redis (якщо використовується) ---
# REDIS_HOST=localhost # Адреса сервера Redis
# REDIS_PORT=6379 # Порт сервера Redis
# REDIS_PASSWORD= # Пароль для Redis (якщо встановлено)

# --- Налаштування Celery (якщо використовується) ---
# CELERY_BROKER_URL=redis://localhost:6379/0 # URL брокера повідомлень для Celery
# CELERY_RESULT_BACKEND=redis://localhost:6379/0 # URL бекенду результатів для Celery

# --- Налаштування електронної пошти (SMTP) ---
# SMTP_TLS=True # Використовувати TLS для SMTP (True/False)
# SMTP_PORT=587 # Порт SMTP сервера
# SMTP_HOST=smtp.example.com # Адреса SMTP сервера
# SMTP_USER=your_email@example.com # Ім'я користувача для SMTP
# SMTP_PASSWORD=your_email_password # Пароль для SMTP
# EMAILS_FROM_EMAIL=noreply@example.com # Email відправника за замовчуванням

# --- Інші налаштування ---
# API префікс
API_V1_STR=/api/v1
# Шлях для завантажених файлів (якщо використовується)
# UPLOAD_DIR=/app/uploads # Каталог для завантажених файлів

# Логування
# Рівень логування (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
# Формат логування (TEXT, JSON)
LOG_FORMAT=TEXT

# Ліміти запитів (Rate Limiting)
# REQUESTS_PER_MINUTE=100 # Максимальна кількість запитів на хвилину

# Налаштування для першого користувача (суперюзера) - створюється при старті, якщо змінних немає в БД
# FIRST_SUPERUSER_EMAIL=admin@example.com # Email суперкористувача
# FIRST_SUPERUSER_PASSWORD=your_strong_password # Пароль суперкористувача
# FIRST_SUPERUSER_USERNAME=admin # Ім'я користувача суперкористувача
